  "review_agents": [
    {
      "name": "reviewer",
      "prompt_suffix": "Review these changes for correctness, simplification opportunities, and test coverage."
    }
  ],
  "plan_agents": [
    {
      "name": "plan-critic",
      "prompt_suffix": "Critique this plan."
    }
  ],
  "review_brief_fields": [
    {
      "flag": "intent",
      "label": "Intent (what the user wanted)",
      "required": true
    },
    {
      "flag": "approach",
      "label": "Approach (what was done and why)",
      "required": true
    },
    {
      "flag": "limitations",
      "label": "Limitations",
      "required": false
    },
    {
      "flag": "alternatives",
      "label": "Alternatives Considered",
      "required": false
    }
  ],
  "batch_size": 12
}