{
  "docs": [
    "CLAUDE.md",
    "DOCS/FEATURES.md",
    "DOCS/ARCHITECTURE.md",
    "DOCS/PHILOSOPHY.md"
  ],
  "review_agents": [
    {
      "name": "reviewer",
      "prompt_suffix": "Review these changes."
    },
    {
      "name": "simplifier",
      "prompt_suffix": "Analyze for simplification opportunities."
    },
    {
      "name": "tester",
      "prompt_suffix": "Run tests, identify coverage gaps, suggest tests to write."
    }
  ],
  "plan_agents": [
    {
      "name": "critic-risk",
      "prompt_suffix": "Critique this plan."
    },
    {
      "name": "critic-reuse",
      "prompt_suffix": "Critique this plan."
    },
    {
      "name": "critic-abstraction",
      "prompt_suffix": "Critique this plan."
    }
  ],
  "review_brief_fields": [
    {
      "flag": "intent",
      "label": "Intent (what the user wanted)",
      "required": true
    },
    {
      "flag": "approach",
      "label": "Approach (what was done and why)",
      "required": true
    },
    {
      "flag": "limitations",
      "label": "Limitations",
      "required": false
    },
    {
      "flag": "alternatives",
      "label": "Alternatives Considered",
      "required": false
    }
  ],
  "batch_size": 12
}
