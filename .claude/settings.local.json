{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(claude install:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(claude plugin:*)",
      "Bash(npx tsc:*)",
      "Bash(cd:*)",
      "Bash(npm test:*)",
      "Read(//c/Users/jorda/PycharmProjects/claude_tabs/$USERPROFILE/.claude/**)",
      "Bash(ls -d */)",
      "Bash(PROJ=\"C:/Users/jorda/.claude/projects/C--Users-jorda-PycharmProjects-claude-tabs\")",
      "Read(//c/Users/jorda/PycharmProjects/claude_tabs/$PROJ/**)",
      "Bash(python3 -m json.tool)",
      "Bash(ls:*)",
      "Bash(python3 -c \"import sys,json; d=json.loads\\(sys.stdin.readline\\(\\)\\); print\\(''''sessionId:'''', d.get\\(''''sessionId'''',''''NONE''''\\)\\)\")",
      "Bash(npm run:*)",
      "Bash(bash \"$LOCALAPPDATA/claude-agent-logs/bin/tag-info.sh\" stats)",
      "Bash(bash \"$LOCALAPPDATA/claude-agent-logs/bin/tag-info.sh\" lookup TB-01)",
      "Bash(bash \"$LOCALAPPDATA/claude-agent-logs/bin/start.sh\" 2>&1)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$LOCALAPPDATA/claude-agent-logs/bin/block-doc-edits.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | head -3 | tr '\\n' ' ' | sed 's/.*error.*/{ \"systemMessage\": \"TypeScript errors introduced — fix before continuing.\" }/' | grep -q systemMessage && npx tsc --noEmit 2>&1 | head -3 | tr '\\n' ' ' | sed 's/.*error.*/{ \"systemMessage\": \"TypeScript errors introduced — fix before continuing.\" }/' || echo '{}'",
            "timeout": 30,
            "statusMessage": "Type-checking..."
          }
        ]
      }
    ]
  }
}
