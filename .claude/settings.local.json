      "Bash(bash \"$LOCALAPPDATA/claude-agent-logs/bin/tag-info.sh\" lookup TB-01)",
      "Bash(bash \"$LOCALAPPDATA/claude-agent-logs/bin/start.sh\" 2>&1)",
      "Bash(bash \"C:/Users/jorda/AppData/Local/claude-agent-logs/bin/tag-edit.sh\" --tag PT-14 --remove 2>&1)",
      "Bash(fi)",
      "Bash(bash \"$AGENT_PROOFS_BIN/merge-worktree.sh\" worktree-immutable-orbiting-ember --message \"Add /changelog command and clean up stale .claude files\")",
      "Bash(echo \"$AGENT_PROOFS_BIN\")",
