{
  "name": "code-tabs",
  "private": true,
  "version": "0.64.3",
  "type": "module",
  "x-proofd-anchors": "[BV-02] build:quick / build:debug scripts; [BV-03] pre-commit gate -> npx tsc --noEmit + npm test (vitest run) + cargo check --manifest-path src-tauri/Cargo.toml",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:quick": "npm run proof:sync && tauri build --no-bundle",
    "build:debug": "npm run proof:sync && tauri build --debug --no-bundle",
    "build:release": "npm run proof:sync && cross-env NO_STRIP=true tauri build",
    "proofd": "python tools/proofd.py",
    "proof:sync": "python tools/proofd.py sync",
    "proof:lint": "python tools/proofd.py lint",
    "proof:mcp": "python tools/proofd.py mcp",
    "codex:handoff": "python tools/codex_handoff.py",
    "codex:delegate": "python tools/codex_delegate.py",
    "discover:dump": "cargo run --manifest-path src-tauri/Cargo.toml --bin discover_audit -- dump",
    "discover:audit": "cargo run --manifest-path src-tauri/Cargo.toml --bin discover_audit -- audit",
    "discover:fetch-docs": "cargo run --manifest-path src-tauri/Cargo.toml --bin discover_audit -- fetch-docs --out src-tauri/tests/fixtures",
    "discover:fetch-codex-schema": "curl -fsSL https://raw.githubusercontent.com/openai/codex/main/codex-rs/core/config.schema.json -o src-tauri/src/discovery/codex_schema.json && echo 'Refreshed src-tauri/src/discovery/codex_schema.json from openai/codex@main'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "shell-quote": "^1.8.3",
    "smol-toml": "^1.6.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/shell-quote": "^1.7.5",
    "@vitejs/plugin-react": "^4.4.0",
    "cross-env": "^10.1.0",
    "terser": "^5.46.1",
    "typescript": "~5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.4"
  }
}
